# 外运物流控制塔 - 环境变量配置示例

# 项目配置
PROJECT_NAME=外运物流控制塔
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/logistics_control_tower
DATABASE_ECHO=false

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_EXPIRE_SECONDS=3600

# RabbitMQ配置
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# CORS配置
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# TimesFM预测服务配置
PREDICTION_SERVICE_URL=http://localhost:8001
TIMESFM_MODEL_PATH=google/timesfm-2.5-200m-pytorch
TIMESFM_DEVICE=cpu

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
